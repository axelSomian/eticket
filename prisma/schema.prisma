generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SCANNER
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      UserRole @default(SCANNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}

enum TicketType {
  INDIVIDUEL
  GBONHI
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

model Ticket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique
  ticketType   TicketType   @default(INDIVIDUEL)
  note         String?
  status       TicketStatus @default(VALID)
  signature    String
  usedAt       DateTime?
  scannedBy    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ticketNumber])
  @@index([status])
}
