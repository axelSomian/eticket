generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SCANNER
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      UserRole @default(SCANNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}

enum TicketType {
  VIP
  STANDARD
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

model Ticket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique
  firstName    String
  lastName     String
  email        String?
  phone        String?
  ticketType   TicketType   @default(STANDARD)
  tableId      String?
  table        Table?       @relation(fields: [tableId], references: [id])
  note         String?
  status       TicketStatus @default(VALID)
  signature    String
  usedAt       DateTime?
  scannedBy    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ticketNumber])
  @@index([status])
  @@index([tableId])
}

model Table {
  id        String   @id @default(uuid())
  number    String   @unique
  capacity  Int
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([number])
}
